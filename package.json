{
  "name": "@eldwin-ai/extension-read-only-toolkit",
  "version": "0.1.0",
  "description": "Shared read-only agent tool helpers — diagnostics, enterprise API reads, command packs, shell policy.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    "./devops-diagnostics": "./src/devops-diagnostics.mjs",
    "./devops-data-paths": "./src/devops-data-paths.mjs",
    "./read-only-command-pack": "./src/read-only-command-pack.mjs",
    "./read-only-plan": "./src/read-only-plan.mjs",
    "./read-only-shell-policy": "./src/read-only-shell-policy.mjs",
    "./enterprise-api-read": "./src/enterprise-api-read.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "src"
  ],
  "scripts": {
    "test": "npm exec -- eldwin-package-test",
    "test:unit": "npm exec -- eldwin-package-test -- --unit",
    "test:mock": "npm exec -- eldwin-package-test -- --mock",
    "test:integration": "npm exec -- eldwin-package-test -- --integration"
  },
  "agentRuntimeDistribution": {
    "visibility": "public",
    "group": "read-only-toolkit",
    "serviceGrouping": "single-service",
    "publicService": false,
    "rationale": "Library extension — shared read-only helpers imported by domain extensions and products."
  },
  "dependencies": {
    "@eldwin-ai/eldwin": "^0.1.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "vitest": "^3.1.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eldwin-ai/extension-read-only-toolkit.git"
  }
}
